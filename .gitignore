# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Editor / accidental Rich Text exports next to source files
*.rtf

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
/data/events.ndjson
/data/preferences.json

# Catalog round-trip (generated CSVs + local snapshots; keep out of git if you prefer)
/data/catalog-sheet-export/
/catalog-merged.json
/catalog-before.json
/catalog-after.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
